{
    "$schema": "https://opencode.ai/config.json",
    "model": "my-custom-provider/gpt-5.5",
    "provider": {
        "my-custom-provider": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "我的自定义API",
            "options": {
                "baseURL": "{env:OPENCODE_API_BASE_URL}",
                "apiKey": "{env:OPENCODE_API_KEY}"
            },
            "models": {
                "gpt-5.5": {
                    "name": "GPT-5.5"
                }
            }
        }
    }
}